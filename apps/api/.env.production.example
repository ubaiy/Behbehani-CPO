# apps/api/.env.production.example
#
# Template for the production API .env. Copy to apps/api/.env on the EC2 server,
# fill in every value marked <CHANGE_ME>, and `chmod 600 apps/api/.env`.
#
# DO NOT commit the real .env to git. Only this .example file is tracked.
#
# Generated for the v1.5.17 deployment runbook (docs/DEPLOY.md).

# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# JWT secrets — generate strong values, MUST differ from each other:
#   openssl rand -hex 48     (run twice, paste below)
JWT_ACCESS_SECRET=<CHANGE_ME_48_HEX_CHARS_MIN>
JWT_REFRESH_SECRET=<CHANGE_ME_DIFFERENT_48_HEX_CHARS>
JWT_ACCESS_TTL_SEC=86400
JWT_REFRESH_TTL_SEC=2592000

# ─── Database (RDS Postgres) ──────────────────────────────────────────────────
# Endpoint format: HOST.REGION.rds.amazonaws.com
# ?sslmode=require is REQUIRED — RDS rejects plain connections.
DATABASE_URL=postgresql://cpo_admin:<RDS_PASSWORD>@<RDS_ENDPOINT>:5432/cpo?sslmode=require

# ─── Cache + rate-limit store (ElastiCache Redis) ─────────────────────────────
# rediss:// (note the double 's') = TLS-encrypted. ElastiCache 7+ defaults to TLS.
# If you turned encryption-in-transit OFF, change to redis://
REDIS_URL=rediss://<ELASTICACHE_ENDPOINT>:6379

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list. NO trailing slashes. Must EXACTLY match the Origin header
# the customer browser sends. Include both apex + www variants if both serve UI.
CORS_ORIGINS=https://www.behbehanimotors.com,https://admin.behbehanimotors.com

# ─── S3 media bucket ──────────────────────────────────────────────────────────
S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
S3_REGION=eu-central-1
S3_BUCKET=behbehani-cpo-media-prod

# ACCESS_KEY + SECRET_KEY: LEAVE EMPTY if the EC2 instance has an IAM role
# (cpo-ec2-role per DEPLOY.md §1.1.f) — AWS SDK auto-picks role credentials.
# Only fill these if you must use static IAM-user keys (less secure, rotated manually).
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Public base for served assets. If using CloudFront in front of S3,
# set this to https://cdn.behbehanimotors.com. Otherwise direct S3 URL.
S3_PUBLIC_BASE_URL=https://behbehani-cpo-media-prod.s3.eu-central-1.amazonaws.com
S3_FORCE_PATH_STYLE=false
S3_PRESIGN_TTL_SEC=900

# Per-type upload size caps (bytes). Defaults are fine; bump for premium tiers.
MAX_PHOTO_BYTES=10485760
MAX_VIDEO_BYTES=104857600
MAX_360_BYTES=262144000
MAX_AVATAR_BYTES=5242880

# ─── CDN prefix for relative-path assets (avatars) ────────────────────────────
# Same value as S3_PUBLIC_BASE_URL unless you have a separate CDN.
CDN_BASE_URL=https://behbehani-cpo-media-prod.s3.eu-central-1.amazonaws.com

# ─── Inspection signing email/SMS link base ───────────────────────────────────
# The customer-facing storefront URL where /inspection-sign/:token resolves.
SIGN_LINK_BASE_URL=https://www.behbehanimotors.com
SIGN_LINK_TTL_DAYS=7

# ─── Aging engine cron (price drops on stale listings) ────────────────────────
# Runs daily 02:00 Asia/Kuwait. Disable via false if you want to defer.
AGING_ENGINE_CRON=0 2 * * *
AGING_ENGINE_TZ=Asia/Kuwait
AGING_ENGINE_ENABLED=true

# ─── OTP (customer auth) ──────────────────────────────────────────────────────
OTP_TTL_MINUTES=5

# ─── Notifications providers ──────────────────────────────────────────────────
# 'devlog' = writes to apps/api/.dev/notifications.log (mock fallback)
# 'unifonic' / 'sendgrid' = real send. FLIP THESE only after creds are filled in
# AND you've smoke-tested in staging.
NOTIFICATIONS_SMS_PROVIDER=devlog
NOTIFICATIONS_EMAIL_PROVIDER=devlog
EMAIL_FROM_ADDRESS=concierge@behbehanimotors.com

# Unifonic (SMS for OTP + inspection-sign links)
UNIFONIC_APP_ID=
UNIFONIC_SENDER_ID=Behbehani

# SendGrid (email for OTP + inspection-sign links)
SENDGRID_API_KEY=

# ─── Optional: Google OAuth (for "Sign in with Google") ───────────────────────
# Empty = endpoint returns 501. Fill when Google sign-in goes live.
GOOGLE_OAUTH_CLIENT_ID=

# ─── Optional: Push notifications (mobile) ────────────────────────────────────
# FIREBASE_SERVICE_ACCOUNT_PATH — absolute file path to firebase-admin.json.
# Store the JSON under /opt/cpo/apps/api/.secrets/ (chmod 700 dir, 600 file).
# Empty = mock-fallback (push payloads written to .dev/notifications.log).
FIREBASE_SERVICE_ACCOUNT_PATH=

# APNs (iOS) — all 4 must be filled for real iOS push:
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=
APNS_BUNDLE_ID=

# ─── Optional: Otto Payment Services ──────────────────────────────────────────
# OTTO_SANDBOX_MODE=true → mock checkout responses, no real Otto API call.
# Set to false ONLY after sandbox credentials are validated AND you've coordinated
# with Otto on the webhook secret.
OTTO_API_KEY=
OTTO_WEBHOOK_SECRET=
OTTO_HOSTED_BASE_URL=https://sandbox.otto.kw/checkout
OTTO_SANDBOX_MODE=true

# v1.5.28 — Payment bypass mode (for demos without Otto creds)
# When true: /v1/public/orders/:id/payment skips Otto entirely, marks order
# as paid immediately, returns hostedPaymentUrl pointing at our own
# /checkout/return page (which shows success). Customer sees full end-to-end
# flow. Flip to false when real Otto merchant creds arrive.
PAYMENT_BYPASS_MODE=true
