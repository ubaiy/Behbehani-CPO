# Behbehani CPO Mobile — Environment Variables
#
# Copy this file to .env.local and fill in values for local development.
# NEVER commit .env.local to source control.
#
# All public (client-visible) vars MUST be prefixed with EXPO_PUBLIC_
# They are inlined at build time by Metro bundler — do not put secrets here.

# Base URL for the Behbehani CPO API.
# Development: http://localhost:3000
# Staging:     https://api-staging.behbehani-cpo.com
# Production:  https://api.behbehani-cpo.com
EXPO_PUBLIC_API_URL=http://localhost:3000
