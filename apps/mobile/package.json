{
  "name": "@behbehani-cpo/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@behbehani-cpo/data-access-mobile": "*",
    "@behbehani-cpo/shared-types": "*",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@tanstack/query-async-storage-persister": "^5.69.0",
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-query-persist-client": "^5.69.0",
    "axios": "^1.6.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.0",
    "expo-image": "~2.0.0",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.0",
    "expo-local-authentication": "~15.0.0",
    "expo-localization": "~16.0.0",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.2",
    "i18next": "^23.16.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^15.1.0",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.8.0",
    "jest": "^30.0.0",
    "jest-expo": "~52.0.0",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "moduleNameMapper": {
      "^@behbehani-cpo/shared-types$": "<rootDir>/../../libs/shared/types/src/index.ts",
      "^@behbehani-cpo/data-access-mobile$": "<rootDir>/../../libs/data-access-mobile/src/index.ts"
    }
  },
  "nx": {
    "name": "mobile",
    "targets": {
      "serve": {
        "command": "expo start",
        "options": {
          "cwd": "{projectRoot}"
        }
      },
      "build": {
        "command": "eas build --non-interactive",
        "options": {
          "cwd": "{projectRoot}"
        }
      },
      "typecheck": {
        "command": "tsc --noEmit",
        "options": {
          "cwd": "{projectRoot}"
        }
      },
      "lint": {
        "command": "eslint . --ext .ts,.tsx",
        "options": {
          "cwd": "{projectRoot}"
        }
      },
      "test": {
        "command": "jest --passWithNoTests",
        "options": {
          "cwd": "{projectRoot}"
        }
      }
    },
    "implicitDependencies": [
      "shared-types",
      "data-access-mobile"
    ]
  }
}
