{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "sourceMap": true,
    "customConditions": ["@behbehani-cpo/source"],
    "paths": {
      "@behbehani-cpo/shared-types": ["./libs/shared/types/src/index.ts"],
      "@behbehani-cpo/shared-utils": ["./libs/shared/utils/src/index.ts"],
      "@behbehani-cpo/shared-i18n": ["./libs/shared/i18n/src/index.ts"],
      "@behbehani-cpo/shared-ui": ["./libs/shared/ui/src/index.ts"],
      "@behbehani-cpo/data-access": ["./libs/data-access/src/index.ts"],
      "@behbehani-cpo/data-access-mobile": ["./libs/data-access-mobile/src/index.ts"]
    }
  }
}
