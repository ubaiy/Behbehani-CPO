# Behbehani CPO — local environment
# Copy to .env before running `npm run serve:api`. `.env` is gitignored.

NODE_ENV=development
PORT=3333

# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-32chars-or-more
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-32chars-or-more
JWT_ACCESS_TTL_SEC=86400
JWT_REFRESH_TTL_SEC=2592000

DATABASE_URL=postgres://cpo:cpo@localhost:5432/cpo
REDIS_URL=redis://localhost:6379

CORS_ORIGINS=http://localhost:4200,http://localhost:4201

# ─── S3 (MinIO local) ───
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=cpo-media
S3_ACCESS_KEY=cpo-local
S3_SECRET_KEY=cpo-local-secret
S3_PUBLIC_BASE_URL=http://localhost:9000/cpo-media
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL_SEC=900
MAX_PHOTO_BYTES=10485760
MAX_VIDEO_BYTES=104857600
MAX_360_BYTES=262144000

# ─── Aging engine ───
AGING_ENGINE_CRON=0 2 * * *
AGING_ENGINE_TZ=Asia/Kuwait
AGING_ENGINE_ENABLED=true

# ─── Push notification provider creds (v1.4 Day 3) ───────────────────────
# Leave empty to use mock-log fallback (no external calls). Real dispatch
# activates automatically once values are filled in — no code changes needed.
# See apps/api/src/notifications/adapters/push.adapter.ts for details.

# FCM (Android): paste the entire contents of your Firebase serviceAccountKey.json as a single line.
FIREBASE_SERVICE_ACCOUNT_JSON=

# APNs (iOS): obtain from Apple Developer → Certificates, Identifiers & Profiles.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
APNS_BUNDLE_ID=com.behbehani.cpo
