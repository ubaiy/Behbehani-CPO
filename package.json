{
  "name": "@behbehani-cpo/source",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "serve:api": "nx serve api",
    "serve:web": "nx serve web",
    "serve:admin": "nx serve admin",
    "dev:services": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "dev:services:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema apps/api/prisma/schema.prisma",
    "db:seed": "node -r @swc-node/register apps/api/prisma/seed.ts",
    "prepare": "husky install",
    "guard:brand-lock": "node scripts/guard-brand-lock.mjs",
    "guard:i18n-parity": "node scripts/guard-i18n-parity.mjs",
    "guard:i18n-parity-mobile": "node scripts/check-i18n-parity-mobile.mjs",
    "guard:secrets": "node scripts/guard-secrets.mjs",
    "guard:all": "npm run guard:brand-lock && npm run guard:i18n-parity && npm run guard:secrets",
    "mockup-diff": "node scripts/mockup-diff.mjs",
    "visual:install": "cd e2e/web-visual && npx playwright install chromium --with-deps",
    "visual:baseline": "cd e2e/web-visual && npx playwright test --update-snapshots",
    "visual:test": "cd e2e/web-visual && npx playwright test"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
