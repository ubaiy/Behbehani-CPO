    "@nx/web": "22.7.0",
    "@nx/webpack": "22.7.0",
    "@playwright/test": "^1.36.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@schematics/angular": "~21.2.0",
    "@svgr/webpack": "^8.0.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
