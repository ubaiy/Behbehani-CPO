    "nx": "22.7.0",
    "postcss": "^8.4.5",
    "prettier": "^3.8.1",
    "prisma": "^6.2.0",
    "react-refresh": "^0.10.0",
    "tailwindcss": "^3.0.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
