# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

# secrets — never commit credentials, service-account JSON, .p8 keys, etc.
.secrets/
**/.secrets/

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

.claude/worktrees
.claude/settings.local.json
.nx/polygraph
.nx/self-healing
test-output

.angular

# Expo generated cache (per-project — not committed)
apps/mobile/.expo/

# env files
.env
.env.local
.env.*.local

# extracted SRS text (rebuilt from docx)
docs/SRS_Car_Marketplace_Kuwait.txt

# Demo-media source photos — downloaded by scripts/generate-rich-media-demo.mjs
# from Unsplash; intermediate inputs for ffmpeg Ken-Burns walkaround generation.
# The *output* MP4s + poster JPGs ARE committed; only the source JPEGs aren't
# (re-fetchable on demand, saves ~600 KB).
apps/api/src/seed/demo-media/source-photos/
